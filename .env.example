# ── AI Models ──────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Discord ────────────────────────────────────────────────
# Create bot at: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_OWNER_ID=your-discord-user-id

# ── Slack ──────────────────────────────────────────────────
# Create app at: https://api.slack.com/apps
# Bot Token (xoxb-): OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-...
# App Token (xapp-): Settings > Basic Information > App-Level Tokens
SLACK_APP_TOKEN=xapp-...

# ── Signal ─────────────────────────────────────────────────
# Requires signal-cli installed and registered phone number
SIGNAL_PHONE_NUMBER=+1234567890

# ── ClickUp ──────────────────────────────────────────────
# Get from: ClickUp > Settings > Apps > Generate API Token
CLICKUP_API_TOKEN=pk_...
# Optional: auto-detected if not set
CLICKUP_TEAM_ID=your-workspace-id
CLICKUP_USER_ID=your-user-id

# ── xAI (Grok) ───────────────────────────────────────────
# Get from: https://console.x.ai/
XAI_API_KEY=xai-...
